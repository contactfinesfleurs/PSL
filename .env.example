# Database (Neon PostgreSQL - Prisma)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Auth
JWT_SECRET="your-secret-key-min-32-chars"
CRON_SECRET="your-cron-secret-min-32-chars"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# 17track API (package tracking)
SEVENTEEN_TRACK_API_KEY="your-17track-api-key"

# Anthropic (AI agents)
ANTHROPIC_API_KEY="sk-ant-..."

# Email (Resend) — for project invitation emails
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# App URL — used in invitation emails
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
