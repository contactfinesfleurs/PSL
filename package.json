{
  "name": "psl-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma db push --accept-data-loss && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "agents": "tsx scripts/run-agents.ts",
    "agents:security": "tsx scripts/run-agents.ts --security-only",
    "agents:design": "tsx scripts/run-agents.ts --design-only",
    "agents:no-code": "tsx scripts/run-agents.ts --no-code",
    "blob:migrate": "tsx scripts/migrate-blobs-to-private.ts",
    "blob:migrate:dry": "tsx scripts/migrate-blobs-to-private.ts --dry-run",
    "admin:promote": "tsx scripts/make-super-admin.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@logtail/node": "^0.5.8",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^4.0.0",
    "@sentry/nextjs": "^10.43.0",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jose": "^6.2.1",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.4.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
