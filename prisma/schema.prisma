generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── PROFILE ROLE ─────────────────────────────────────────────────────────────

enum ProfileRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

// ─── TEAM ─────────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  description String?

  members Profile[]
}

// ─── PROFILE (AUTH) ───────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  email        String @unique
  passwordHash String

  role   ProfileRole @default(MEMBER)
  teamId String?
  team   Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Set to the current timestamp when the user changes their password (H-16).
  // Any JWT issued before this moment is considered invalid.
  tokensInvalidatedAt DateTime?

  // Plan & Billing
  plan             String  @default("FREE") // FREE | PRO
  stripeCustomerId String? @unique

  products  Product[]
  events    Event[]
  campaigns Campaign[]

  ownedProjects        Project[]
  projectMemberships   ProjectCollaborator[]
  projectContributions ProjectContribution[]
  sentInvitations      ProjectInvitation[] @relation("InvitationsSent")
  receivedInvitations  ProjectInvitation[] @relation("InvitationsReceived")
  passwordResetTokens  PasswordResetToken[]
  productShares        ProductShare[]
  subscription         Subscription?
  teamMembers          TeamMember[]
  memberOf             TeamMember[]  @relation("MemberProfile")

  @@index([role])
  @@index([teamId])
}

// ─── SUBSCRIPTION (STRIPE) ──────────────────────────────────────────────────

model Subscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profileId String  @unique
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String   // active | past_due | canceled | incomplete | trialing
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
}

// ─── TEAM MEMBER (COLLABORATION) ────────────────────────────────────────────

model TeamMember {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  ownerId String
  owner   Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  memberId String
  member   Profile @relation("MemberProfile", fields: [memberId], references: [id], onDelete: Cascade)

  role String @default("VIEWER") // VIEWER | EDITOR

  @@unique([ownerId, memberId])
  @@index([ownerId])
  @@index([memberId])
}

// ─── PRODUCT ─────────────────────────────────────────────────────────────────

model Product {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Profile isolation
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Identity
  name      String
  sku       String  @unique
  reference String?

  // Classification
  family String // accessories | pret-a-porter | shoes | leather-goods | small-leather-goods | other
  season String // FALL-WINTER | PRE-FALL | SPRING-SUMMER | CRUISE
  year   Int

  // Sizing
  sizeRange String // S-XL | 30-44 | 35-46 | ONE-SIZE | etc.
  sizes     String // JSON array stored as string

  // Tech Pack
  measurements String? // free text notes
  materials    String? // JSON array
  colors       String? // JSON array — codes couleur e.g. ["02","01"] (primary, secondary)
  sketchPaths  String? // JSON array of file paths
  techPackPath String? // path to tech pack file

  // Descriptions (filled after validation)
  description String?
  metaTags    String? // JSON array

  // Status: PENDING | VALIDATED | NOT_VALIDATED
  sampleStatus    String    @default("PENDING")
  plannedLaunchAt DateTime?

  // Variants — products sharing the same variantGroupId are color variants of each other
  variantGroupId String?

  // Relations
  samples    Sample[]
  campaigns  CampaignProduct[]
  events     EventProduct[]
  loans      SampleLoan[]
  placements MediaPlacement[]
  shares     ProductShare[]
  projectLinks    ProjectProduct[]
  projectContributions ProjectContribution[]

  @@index([profileId])
  @@index([profileId, deletedAt])
  @@index([profileId, season, year])
  @@index([profileId, family])
  @@index([sampleStatus])
  @@index([variantGroupId])
  @@index([profileId, variantGroupId])
}

// ─── SAMPLE ──────────────────────────────────────────────────────────────────

model Sample {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Photos
  samplePhotoPaths String? // JSON array - main sample photos
  detailPhotoPaths String? // JSON array - important detail photos
  reviewPhotoPaths String? // JSON array - details "to review"

  // Review notes
  reviewNotes String?

  // Supplier info
  supplierName    String?
  supplierAddress String?
  supplierCountry String?

  // Logistics
  shippingDate   DateTime?
  trackingNumber String?
  trackingStatus String? // InTransit | Delivered | NotFound | etc.
  receivedAt     DateTime? // auto-filled when 17track marks as delivered

  // Final product (unlocked after validation)
  packshotPaths       String? // JSON array - official packshots
  definitiveColors    String? // JSON array
  definitiveMaterials String? // JSON array

  loans SampleLoan[]

  @@index([productId])
}

// ─── EVENT ───────────────────────────────────────────────────────────────────

model Event {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Profile isolation
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String // SHOW | PRESENTATION | LAUNCH | PRESS | TRADE-SHOW | OTHER
  // Status: DRAFT | CONFIRMED | COMPLETED | CANCELLED
  status      String  @default("DRAFT")

  startAt  DateTime
  endAt    DateTime?
  location String?
  venue    String?

  // Relations
  campaigns Campaign[]
  products  EventProduct[]
  guests    EventGuest[]

  @@index([profileId])
  @@index([status])
  @@index([deletedAt])
}

// ─── CAMPAIGN ────────────────────────────────────────────────────────────────

model Campaign {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Profile isolation
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String // DIGITAL | PRINT | OOH | SOCIAL | INFLUENCER | OTHER
  // Status: DRAFT | ACTIVE | PAUSED | COMPLETED | CANCELLED
  status      String  @default("DRAFT")

  startAt  DateTime?
  endAt    DateTime?
  budget   Float?
  currency String?   @default("EUR")

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  // Relations
  products CampaignProduct[]

  @@index([profileId])
  @@index([status])
  @@index([deletedAt])
}

// ─── SAMPLE LOAN ─────────────────────────────────────────────────────────────
// Track physical sample circulation to press, stylists, influencers, etc.

model SampleLoan {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sampleId  String
  sample    Sample  @relation(fields: [sampleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Recipient
  contactName String
  contactRole String? // Styliste | Rédactrice | Influenceur | Showroom | Presse | Célébrité
  publication String? // Magazine or media name if editorial/press

  // Purpose: EDITORIAL | PRESS | EVENT | SHOWROOM | INFLUENCER | CELEBRITY
  purpose String

  // Timeline
  sentAt     DateTime  @default(now())
  dueAt      DateTime?
  returnedAt DateTime?

  // Status: SENT | RETURNED | LOST
  status String  @default("SENT")
  notes  String?

  placements MediaPlacement[]

  @@index([sampleId])
  @@index([productId])
  @@index([status])
}

// ─── MEDIA PLACEMENT ─────────────────────────────────────────────────────────
// Track press/editorial/social coverage generated from sample loans

model MediaPlacement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sampleLoanId String?
  sampleLoan   SampleLoan? @relation(fields: [sampleLoanId], references: [id], onDelete: SetNull)

  publication    String
  // Type: PRINT | DIGITAL | SOCIAL | TV | PODCAST
  type           String
  publishedAt    DateTime
  url            String?
  screenshotPath String?
  notes          String?
  // Estimated audience reach
  reach          Int?

  @@index([productId])
  @@index([sampleLoanId])
}

// ─── EVENT GUEST ─────────────────────────────────────────────────────────────
// Guest list management with RSVP and check-in for fashion events

model EventGuest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  email     String?
  phone     String?
  instagram String?
  company   String?
  title     String?

  // Category: VIP | PRESS | BUYER | INFLUENCER | INDUSTRY | GUEST
  category  String  @default("GUEST")
  invitedBy String?

  // RSVP: INVITED | CONFIRMED | DECLINED | WAITLIST
  rsvpStatus String @default("INVITED")

  // Check-in on the day of the event
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?

  // Seating
  tableNumber String?
  seatNumber  String?

  notes String?

  @@index([eventId])
  @@index([rsvpStatus])
}

// ─── JUNCTION TABLES ─────────────────────────────────────────────────────────

model CampaignProduct {
  id         String   @id @default(cuid())
  campaignId String
  productId  String
  addedAt    DateTime @default(now())
  notes      String?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
}

// ─── PRODUCT SHARE ────────────────────────────────────────────────────────────
// Allows an external user to view a product and add photos/notes via a short code.

model ProductShare {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  code      String   @unique // short alphanumeric code, e.g. "a3f9c12b"
  label     String?  // optional description, e.g. "Lien pour Valentino"

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  profileId String   // owner who created the share
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  expiresAt DateTime? // optional expiry

  contributions ShareContribution[]

  @@index([productId])
  @@index([profileId])
}

model ShareContribution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  shareId String
  share   ProductShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  authorName String?  // optional display name provided by contributor
  photoPaths String?  // JSON array of stored paths
  note       String?  // optional text note

  @@index([shareId])
  @@index([shareId, createdAt])
}

model EventProduct {
  id        String   @id @default(cuid())
  eventId   String
  productId String
  addedAt   DateTime @default(now())
  notes     String?
  look      Int? // look number for fashion shows

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([eventId, productId])
}

// ─── PROJECT (COLLABORATIVE COLLECTIONS) ─────────────────────────────────────
// An authenticated profile creates a Project (e.g. SS26), adds products to it,
// then shares a join code with collaborators. Collaborators can view all products
// in the project and add photos/notes (contributions) but cannot edit or delete.

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  code        String  @unique // join code, e.g. "a3f9c12b" (8 hex chars)

  profileId String  // owner
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  products      ProjectProduct[]
  collaborators ProjectCollaborator[]
  contributions ProjectContribution[]
  invitations   ProjectInvitation[]

  @@index([profileId])
}

model ProjectProduct {
  id        String   @id @default(cuid())
  addedAt   DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([projectId, productId])
  @@index([projectId])
  @@index([productId])
}

model ProjectCollaborator {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([projectId, profileId])
  @@index([projectId])
  @@index([profileId])
}

model ProjectContribution {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  profileId String   // collaborator who contributed
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  photoPaths String? // JSON array of stored paths
  note       String?

  @@index([projectId])
  @@index([productId])
  @@index([profileId])
}

model ProjectInvitation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  invitedByProfileId String
  invitedByProfile   Profile @relation("InvitationsSent", fields: [invitedByProfileId], references: [id], onDelete: Cascade)

  invitedEmail     String   // email address of the invitee
  invitedProfileId String?  // set if the email matches a registered profile
  invitedProfile   Profile? @relation("InvitationsReceived", fields: [invitedProfileId], references: [id], onDelete: SetNull)

  status    String    @default("PENDING") // PENDING | ACCEPTED | DECLINED
  expiresAt DateTime? // invitation expires after this date (null = never)

  @@unique([projectId, invitedEmail])
  @@index([projectId])
  @@index([invitedEmail])
  @@index([invitedProfileId])
  @@index([expiresAt])
}

// ─── REVOKED TOKEN ────────────────────────────────────────────────────────────
// Tracks JWT IDs (jti) that have been revoked on logout before their expiry.

model RevokedToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── PASSWORD RESET TOKEN ─────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  profileId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}
